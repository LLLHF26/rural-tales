{
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "target": "es5",
    "declaration": true,
    "noEmitOnError": false,
    "noEmit": false, // Set to false to generate output files
    "allowImportingTsExtensions": false,
    "sourceMap": true,
    "module": "CommonJS",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
