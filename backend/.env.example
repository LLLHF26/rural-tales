# ============================================================
# 沉浸式乡村文旅剧本创作与智能导览系统 —— 环境配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ------------------------- 应用基础 -------------------------
APP_NAME=RuralTourism
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string

# ------------------------- 服务端口 -------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ------------------------- 数据库 -------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=rural_tourism

# ------------------------- Redis -------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ------------------------- JWT 认证 -------------------------
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ------------------------- 短信验证码 -------------------------
SMS_DEBUG_MODE=true
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=乡村文旅
SMS_TEMPLATE_CODE=SMS_123456789

# ============================================================
# AI 服务配置
# ============================================================

# ------------------------- AI 剧本生成 (DeepSeek) -------------------------
SCRIPT_LLM_PROVIDER=deepseek
SCRIPT_LLM_API_KEY=your_deepseek_api_key
SCRIPT_LLM_BASE_URL=https://api.deepseek.com
SCRIPT_LLM_MODEL=deepseek-v4-pro
SCRIPT_LLM_MAX_TOKENS=16384
SCRIPT_LLM_TEMPERATURE=0.8

# ------------------------- AI NPC 对话 (DeepSeek) -------------------------
CHAT_LLM_PROVIDER=deepseek
CHAT_LLM_API_KEY=your_deepseek_api_key
CHAT_LLM_BASE_URL=https://api.deepseek.com
CHAT_LLM_MODEL=deepseek-v4-flash
CHAT_LLM_ENABLE_THINKING=false
CHAT_LLM_MAX_TOKENS=1024
CHAT_LLM_TEMPERATURE=0.9
CHAT_CONTEXT_ROUNDS=20

# ------------------------- AI 图片生成 (智谱 GLM) -------------------------
IMAGE_LLM_PROVIDER=zhipu
IMAGE_LLM_API_KEY=your_zhipu_api_key
IMAGE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
IMAGE_LLM_MODEL=cogview-4
IMAGE_DEFAULT_SIZE=1536x864
IMAGE_DEFAULT_STYLE=realistic
IMAGE_NEGATIVE_PROMPT=blurry, watermark, text, signature, low quality, distorted, modern buildings

# ============================================================
# 对象存储 (阿里云 OSS)
# ============================================================
OSS_PROVIDER=aliyun
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key
OSS_ACCESS_KEY_SECRET=your_oss_secret
OSS_BUCKET_NAME=your_bucket_name

# ============================================================
# 地图服务 (高德)
# ============================================================
MAP_PROVIDER=amap
MAP_API_KEY=your_amap_api_key

# ============================================================
# 部署
# ============================================================
DOCKER_PORT=8000
